@model MMZM.BloodDonationMS.Domain.Features.Auth.RegisterRequest
@{
    ViewData["Title"] = "Register";
}

<div class="auth-container" style="max-width: 500px;">
    <h2 style="text-align: center; margin-bottom: 2rem; color: var(--primary-red);">Create Account</h2>
    
    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" style="color: #ff5252; margin-bottom: 1rem;"></div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                <label asp-for="Name" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="John Doe" required />
            </div>
            
            <div class="form-group">
                <label asp-for="Email" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Email</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com" required />
            </div>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                <label asp-for="Password" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
            </div>
            
            <div class="form-group">
                <label asp-for="RoleId" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">I am a...</label>
                <select asp-for="RoleId" class="form-control" required>
                    <option value="">Select Role</option>
                    <option value="2">Donor</option>
                    <option value="3">Requester</option>
                </select>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                <label asp-for="Phone" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Phone</label>
                <input asp-for="Phone" class="form-control" placeholder="09xxxxxxx" />
            </div>
            
            <div class="form-group">
                <label asp-for="BloodGroup" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Blood Group</label>
                <select asp-for="BloodGroup" class="form-control">
                    <option value="">Select</option>
                    <option value="A+">A+</option>
                    <option value="A-">A-</option>
                    <option value="B+">B+</option>
                    <option value="B-">B-</option>
                    <option value="AB+">AB+</option>
                    <option value="AB-">AB-</option>
                    <option value="O+">O+</option>
                    <option value="O-">O-</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Address" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Address</label>
            <textarea asp-for="Address" class="form-control" rows="2" placeholder="Your street address..."></textarea>
        </div>
        
        <button type="submit" class="btn-primary" style="width: 100%; margin-top: 1rem;">Register Now</button>
    </form>
    
    <p style="text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: var(--text-muted);">
        Already have an account? <a asp-action="Login" style="color: var(--primary-red); text-decoration: none;">Login here</a>
    </p>
</div>
