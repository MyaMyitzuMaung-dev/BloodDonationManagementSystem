@{
    ViewData["Title"] = "Home";
}

<div class="hero">
    <h1 style="font-size: 4rem; font-weight: 800; margin-bottom: 1.5rem; letter-spacing: -2px;">
        GIVE BLOOD<br /><span style="color: var(--primary-red);">SAVE LIVES</span>
    </h1>
    <p style="font-size: 1.25rem; color: var(--text-muted); max-width: 600px; margin: 0 auto 3rem auto; line-height: 1.6;">
        Every year millions of people rely on blood donations. Join our community of life-savers and help us ensure no one waits for blood.
    </p>
    
    <div style="display: flex; gap: 1.5rem; justify-content: center;">
        <a asp-controller="Request" asp-action="Index" class="btn-primary" style="padding: 1rem 2rem; font-size: 1.1rem; text-decoration: none;">FIND REQUESTS</a>
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a asp-controller="Account" asp-action="Register" class="btn-primary" style="background: transparent; border: 1px solid var(--glass-border); padding: 1rem 2rem; font-size: 1.1rem; text-decoration: none;">BECOME A DONOR</a>
        }
    </div>
</div>

<div class="container" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 4rem;">
    <div class="card" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">🩸</div>
        <h3>Donate</h3>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Register as a donor and respond to local requests in real-time.</p>
    </div>
    <div class="card" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">📢</div>
        <h3>Request</h3>
        <p style="color: var(--text-muted); font-size: 0.9rem;">In need of blood? Create a request and reach out to our network instantly.</p>
    </div>
    <div class="card" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">💬</div>
        <h3>Connect</h3>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Communicate with donors and keep track of your donation progress.</p>
    </div>
</div>
