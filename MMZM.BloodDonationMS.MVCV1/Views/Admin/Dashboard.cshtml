@model MMZM.BloodDonationMS.Domain.Features.Reports.DashboardStatsResponse
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="hero">
    <h1 style="color: var(--primary-red);">Admin Dashboard</h1>
    <p style="color: var(--text-muted);">Overview of the Blood Donation Management System.</p>
</div>

<div class="container">
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-bottom: 3rem;">
        <div class="card" style="text-align: center;">
            <h2 style="color: var(--accent-gold); font-size: 2.5rem; margin-bottom: 0;">@Model.TotalDonors</h2>
            <p style="color: var(--text-muted); margin-top: 0.5rem;">Registered Donors</p>
        </div>
        <div class="card" style="text-align: center;">
            <h2 style="color: var(--primary-red); font-size: 2.5rem; margin-bottom: 0;">@Model.TotalRequests</h2>
            <p style="color: var(--text-muted); margin-top: 0.5rem;">Total Requests</p>
        </div>
        <div class="card" style="text-align: center;">
            <h2 style="color: #ffc107; font-size: 2.5rem; margin-bottom: 0;">@Model.PendingRequests</h2>
            <p style="color: var(--text-muted); margin-top: 0.5rem;">Pending Requests</p>
        </div>
        <div class="card" style="text-align: center;">
            <h2 style="color: #4caf50; font-size: 2.5rem; margin-bottom: 0;">@Model.CompletedDonations</h2>
            <p style="color: var(--text-muted); margin-top: 0.5rem;">Successful Donations</p>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
        <div class="card">
            <h3>Blood Group Distribution (Donors)</h3>
            <div style="margin-top: 2rem;">
                @foreach (var stat in Model.BloodGroupStats)
                {
                    <div style="margin-bottom: 1rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.3rem;">
                            <span style="font-weight: 600;">@stat.BloodGroup</span>
                            <span style="color: var(--text-muted);">@stat.Count donors</span>
                        </div>
                        <div style="background: rgba(255,255,255,0.05); height: 8px; border-radius: 4px; overflow: hidden;">
                            <div style="background: var(--primary-red); height: 100%; width: @(stat.Count * 100 / (Model.TotalDonors > 0 ? Model.TotalDonors : 1))%;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
        
        <div class="card">
            <h3>Quick Actions</h3>
            <div style="display: grid; gap: 1rem; margin-top: 1.5rem;">
                <a asp-action="PendingRequests" class="btn-primary" style="text-decoration: none; text-align: center; background-color: var(--accent-gold); color: black;">Approve Requests</a>
                <a asp-action="Users" class="btn-primary" style="text-decoration: none; text-align: center;">Manage Users</a>
                <a asp-controller="Request" asp-action="Index" class="btn-primary" style="background: transparent; border: 1px solid var(--glass-border); text-decoration: none; text-align: center;">Monitor Requests</a>
            </div>
        </div>
    </div>
</div>
