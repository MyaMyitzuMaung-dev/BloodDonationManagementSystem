<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blood Donation MS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">BLOOD SHARE</a>
            <div class="nav-links">
                <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                <a class="nav-link" asp-controller="Donation" asp-action="Index">Donations</a>
                <a class="nav-link" asp-controller="Request" asp-action="Index">Requests</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="nav-link" style="color: var(--accent-gold)">Hello, @User.Identity.Name</span>
                    <a class="nav-link" asp-controller="Account" asp-action="Logout">Logout</a>
                }
                else
                {
                    <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="btn-primary" asp-controller="Account" asp-action="Register" style="text-decoration: none;">Register</a>
                }
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer style="margin-top: 4rem; padding: 2rem; text-align: center; border-top: 1px solid var(--glass-border); color: var(--text-muted);">
        <div class="container">
            &copy; 2026 - Blood Donation Management System - MMZM
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
